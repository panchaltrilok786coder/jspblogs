<!DOCTYPE html>
<html>
<head>
  <title>Add Blog</title>
  <link rel="stylesheet" href="style.css">
</head>

<body>

<header class="navbar">
  <div class="logo">MyBlog Pro</div>

  <div>
    <button class="nav-btn">Home</button>
    <button class="nav-btn">Add Blog</button>
  </div>
</header>

<section class="form-container">

  <div class="form-box">

    <h2 class="form-title">Create Blog</h2>

    <input class="input-field" id="blogTitle" placeholder="Blog Title">

    <textarea class="input-field textarea-field" id="blogContent"
    placeholder="Write your blog..."></textarea>

    <button class="btn-primary" id="addBlogBtn">
      Add Blog
    </button>

  </div>

</section>

<footer class="footer">
  © 2026 MyBlog Pro — All rights reserved
</footer>

</body>
</html>
